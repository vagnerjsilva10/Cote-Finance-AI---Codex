# Server-side Gemini API key used by /api/ai/chat and OCR/classification routes.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL=
NEXT_PUBLIC_APP_URL=
CRON_SECRET=

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_ANNUAL=
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_ANNUAL=

# WhatsApp (Meta Cloud API) Configuration
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0

# Database Configuration
# Important: do not wrap the URL in extra quotes when setting it in Vercel.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require


