# Server-side Gemini API key used by /api/ai/chat and OCR/classification routes.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL=
NEXT_PUBLIC_APP_URL=
ADMIN_EMAILS=
SUPERADMIN_EMAILS=
CRON_SECRET=

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_ANNUAL=
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_ANNUAL=

# WhatsApp (Meta Cloud API) Configuration
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_EXPECTED_DISPLAY_PHONE_NUMBER=
WHATSAPP_EXPECTED_VERIFIED_NAME=
WHATSAPP_ALLOW_TEST_NUMBER=false
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0

# Database Configuration
# Important: do not wrap the URLs in extra quotes when setting them in Vercel.
# DATABASE_URL: pooled/runtime connection (Supabase pooler, usually port 6543).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require
# DIRECT_DATABASE_URL: direct/admin connection (Supabase direct host, usually port 5432).
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@db.PROJECT-REF.supabase.co:5432/postgres?sslmode=require
# Keep migrations out of the Vercel build by default.
PRISMA_SKIP_MIGRATE_DEPLOY=1


