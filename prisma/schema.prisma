generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  avatar_url    String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  profile       Profile?
  workspaces    WorkspaceMember[]
  subscription  SubscriptionEntitlement?
  workspace_events WorkspaceEvent[]
  marketing_attribution MarketingAttribution[]
}

model Profile {
  id                 String   @id @default(uuid())
  user_id            String   @unique
  user               User     @relation(fields: [user_id], references: [id])
  stripe_customer_id String?
  plan               String   @default("FREE") // FREE, PRO, PREMIUM
  tutorial_completed Boolean  @default(false)
  
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
}

model Workspace {
  id            String    @id @default(uuid())
  name          String
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  whatsapp_phone_number String?
  whatsapp_status       String?   @default("DISCONNECTED") // CONNECTED, DISCONNECTED, CONNECTING
  whatsapp_connected_at DateTime?

  members       WorkspaceMember[]
  wallets       Wallet[]
  transactions  Transaction[]
  goals         Goal[]
  debts         Debt[]
  recurring_debts RecurringDebt[]
  investments   Investment[]
  category_suggestions CategorySuggestion[]
  subscription  WorkspaceSubscription?
  preference    WorkspacePreference?
  events        WorkspaceEvent[]
  marketing_attribution MarketingAttribution[]
}

model Goal {
  id            String    @id @default(uuid())
  workspace_id  String
  name          String
  target_amount Decimal   @db.Decimal(12, 2)
  current_amount Decimal   @db.Decimal(12, 2) @default(0)
  deadline      DateTime?
  
  workspace     Workspace @relation(fields: [workspace_id], references: [id])
  created_at    DateTime  @default(now())
}

model Debt {
  id                     String    @id @default(uuid())
  workspace_id           String
  creditor               String
  original_amount        Decimal   @db.Decimal(12, 2)
  remaining_amount       Decimal   @db.Decimal(12, 2)
  interest_rate_monthly  Decimal   @db.Decimal(6, 3)
  due_day                Int
  category               String
  status                 String    @default("ACTIVE") // ACTIVE, PAID
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  workspace              Workspace @relation(fields: [workspace_id], references: [id])

  @@index([workspace_id, created_at])
}


model RecurringDebt {
  id            String    @id @default(uuid())
  workspace_id  String
  creditor      String
  amount        Decimal   @db.Decimal(12, 2)
  category      String
  frequency     String    @default("MONTHLY") // WEEKLY, MONTHLY, QUARTERLY, YEARLY
  interval      Int       @default(1)
  start_date    DateTime
  end_date      DateTime?
  due_day       Int?
  next_due_date DateTime
  status        String    @default("ACTIVE") // ACTIVE, PAUSED, ENDED
  notes         String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  workspace     Workspace @relation(fields: [workspace_id], references: [id])

  @@index([workspace_id, status, next_due_date])
  @@index([workspace_id, created_at])
}
model Investment {
  id                       String    @id @default(uuid())
  workspace_id             String
  name                     String
  type                     String
  institution              String
  invested_amount          Decimal   @db.Decimal(12, 2)
  current_amount           Decimal   @db.Decimal(12, 2)
  expected_return_annual   Decimal   @db.Decimal(6, 3) @default(0)
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  workspace                Workspace @relation(fields: [workspace_id], references: [id])

  @@index([workspace_id, created_at])
}

model SubscriptionEntitlement {
  id            String    @id @default(uuid())
  user_id       String    @unique
  plan          String    @default("FREE")
  status        String    @default("ACTIVE")
  current_period_end DateTime?
  
  user          User      @relation(fields: [user_id], references: [id])
}

model WorkspaceMember {
  id            String    @id @default(uuid())
  workspace_id  String
  user_id       String
  role          String    @default("OWNER") // OWNER, ADMIN, MEMBER

  workspace     Workspace @relation(fields: [workspace_id], references: [id])
  user          User      @relation(fields: [user_id], references: [id])

  @@unique([workspace_id, user_id])
}

model Wallet {
  id            String    @id @default(uuid())
  workspace_id  String
  name          String
  type          String    @default("CASH") // CASH, BANK, CREDIT_CARD, INVESTMENT
  balance       Decimal   @default(0) @db.Decimal(12, 2)

  workspace     Workspace @relation(fields: [workspace_id], references: [id])
  transactions  Transaction[] @relation("PrimaryWalletTransactions")
  incoming_transfers Transaction[] @relation("DestinationWalletTransactions")
}

model Transaction {
  id            String    @id @default(uuid())
  workspace_id  String
  wallet_id     String
  destination_wallet_id String?
  category_id   String?
  
  type          String    // INCOME, EXPENSE, TRANSFER
  payment_method String   @default("OTHER") // PIX, CARD, CASH, BANK_TRANSFER, BOLETO, DEBIT, OTHER
  amount        Decimal   @db.Decimal(12, 2)
  date          DateTime
  due_date      DateTime?
  status        String    @default("CONFIRMED") // PENDING, CONFIRMED, CANCELLED
  description   String
  receipt_url   String?
  
  ai_confidence Float?
  
  workspace     Workspace @relation(fields: [workspace_id], references: [id])
  wallet        Wallet    @relation("PrimaryWalletTransactions", fields: [wallet_id], references: [id])
  destination_wallet Wallet? @relation("DestinationWalletTransactions", fields: [destination_wallet_id], references: [id])
  category      Category? @relation(fields: [category_id], references: [id])

  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt
}

model Category {
  id            String    @id @default(uuid())
  name          String
  icon          String?
  color         String?
  
  transactions  Transaction[]
  suggestions   CategorySuggestion[]
}

model CategorySuggestion {
  id            String    @id @default(uuid())
  workspace_id  String
  keyword       String
  category_id   String?
  category_name String
  confidence    Float     @default(1)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  workspace     Workspace @relation(fields: [workspace_id], references: [id])
  category      Category? @relation(fields: [category_id], references: [id])

  @@unique([workspace_id, keyword])
  @@index([workspace_id, updated_at])
}

model WorkspaceSubscription {
  id                    String    @id @default(uuid())
  workspace_id          String    @unique
  plan                  String    @default("FREE") // FREE, PRO, PREMIUM
  status                String    @default("ACTIVE") // ACTIVE, CANCELED, PENDING
  stripe_customer_id    String?
  stripe_subscription_id String?
  current_period_end    DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  workspace             Workspace @relation(fields: [workspace_id], references: [id])
}

model WorkspacePreference {
  id                    String    @id @default(uuid())
  workspace_id          String    @unique
  onboarding_completed  Boolean   @default(false)
  objective             String?
  financial_profile     String?
  ai_suggestions_enabled Boolean  @default(true)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  workspace             Workspace @relation(fields: [workspace_id], references: [id])
}

model WorkspaceEvent {
  id                    String    @id @default(uuid())
  workspace_id          String
  user_id               String?
  type                  String
  payload               Json?
  created_at            DateTime  @default(now())

  workspace             Workspace @relation(fields: [workspace_id], references: [id])
  user                  User?     @relation(fields: [user_id], references: [id])

  @@index([workspace_id, created_at])
  @@index([user_id, created_at])
  @@index([type, created_at])
}

model PlatformSetting {
  id         String   @id @default(uuid())
  key        String   @unique
  value      Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model MarketingAttribution {
  id               String     @id @default(uuid())
  user_id          String?    @unique
  workspace_id     String?
  user             User?      @relation(fields: [user_id], references: [id])
  workspace        Workspace? @relation(fields: [workspace_id], references: [id])
  landing_path     String?
  initial_referrer String?
  utm_source       String?
  utm_medium       String?
  utm_campaign     String?
  utm_content      String?
  utm_term         String?
  fbclid           String?
  xcod             String?
  raw_params       Json?
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt
  last_seen_at     DateTime   @default(now())

  @@index([utm_source, created_at])
  @@index([utm_campaign, created_at])
  @@index([workspace_id])
}

